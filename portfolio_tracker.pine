string ticker9_id = input.string("SPGI", title="9. SPGI")
float  ticker9_cost = input.float(495.27, title="   Avg. Cost")
float  ticker9_qty  = input.float(41, title="   Quantity")

string ticker10_id = input.string("NFLX", title="10. NFLX")
float  ticker10_cost = input.float(83.03, title="   Avg. Cost")
float  ticker10_qty  = input.float(150, title="   Quantity")

string ticker11_id = input.string("MSFT", title="11. MSFT")
float  ticker11_cost = input.float(412.03, title="   Avg. Cost")
