string ticker11_id   = input.string("MSFT", title="11. MSFT")
float  ticker11_cost = input.float(404.43,  title="   Avg. Cost")
float  ticker11_qty  = input.float(39,      title="   Quantity")
float  ticker11_pct  = input.float(2.94,    title="   % Portfolio")

string ticker12_id   = input.string("DUOL", title="12. DUOL")
float  ticker12_cost = input.float(209.60,  title="   Avg. Cost")
float  ticker12_qty  = input.float(88,      title="   Quantity")
float  ticker12_pct  = input.float(1.77,    title="   % Portfolio")

string ticker13_id   = input.string("EFX", title="13. EFX")
float  ticker13_cost = input.float(236.76,  title="   Avg. Cost")
float  ticker13_qty  = input.float(23,      title="   Quantity")
float  ticker13_pct  = input.float(0.86,    title="   % Portfolio")

string ticker14_id   = input.string("CSPX", title="14. CSPX (AMS)")
float  ticker14_cost = input.float(569.40,  title="   Avg. Cost")
float  ticker14_qty  = input.float(5.281993, title="   Quantity")
float  ticker14_pct  = input.float(0.75,    title="   % Portfolio")

string ticker15_id   = input.string("IWDA", title="15. IWDA (AMS)")
float  ticker15_cost = input.float(111.34,  title="   Avg. Cost")
float  ticker15_qty  = input.float(13.47,   title="   Quantity")
float  ticker15_pct  = input.float(0.35,    title="   % Portfolio")

string ticker16_id   = input.string("SCHG", title="16. SCHG")
float  ticker16_cost = input.float(26.38,   title="   Avg. Cost")
float  ticker16_qty  = input.float(11.00,   title="   Quantity")
float  ticker16_pct  = input.float(0.07,    title="   % Portfolio")

// --- 🧠 LOGIC ---
string simpleTicker = syminfo.ticker
float avgCost = na
float qty     = na
float portPct = na

match(id) => id != "" and (simpleTicker == id or str.contains(syminfo.tickerid, id))

if match(ticker1_id) and syminfo.currency == "CAD"
    avgCost := ticker1_cost
    qty     := ticker1_qty
    portPct := ticker1_pct
else if match(ticker2_id)
    avgCost := ticker2_cost
    qty     := ticker2_qty
    portPct := ticker2_pct
else if match(ticker3_id)
    avgCost := ticker3_cost
    qty     := ticker3_qty
    portPct := ticker3_pct
else if match(ticker4_id)
    avgCost := ticker4_cost
    qty     := ticker4_qty
    portPct := ticker4_pct
else if match(ticker5_id)
    avgCost := ticker5_cost
    qty     := ticker5_qty
    portPct := ticker5_pct
else if match(ticker6_id)
    avgCost := ticker6_cost
    qty     := ticker6_qty
    portPct := ticker6_pct
else if match(ticker7_id)
    avgCost := ticker7_cost
    qty     := ticker7_qty
    portPct := ticker7_pct
else if match(ticker8_id)
    avgCost := ticker8_cost
    qty     := ticker8_qty
    portPct := ticker8_pct
else if match(ticker9_id)
    avgCost := ticker9_cost
    qty     := ticker9_qty
    portPct := ticker9_pct
else if match(ticker10_id)
    avgCost := ticker10_cost
    qty     := ticker10_qty
    portPct := ticker10_pct
else if match(ticker11_id)
    avgCost := ticker11_cost
    qty     := ticker11_qty
    portPct := ticker11_pct
else if match(ticker12_id)
    avgCost := ticker12_cost
    qty     := ticker12_qty
    portPct := ticker12_pct
else if match(ticker13_id)
    avgCost := ticker13_cost
    qty     := ticker13_qty
    portPct := ticker13_pct
else if match(ticker14_id)
    avgCost := ticker14_cost
    qty     := ticker14_qty
    portPct := ticker14_pct
else if match(ticker15_id)
    avgCost := ticker15_cost
    qty     := ticker15_qty
    portPct := ticker15_pct
else if match(ticker16_id)
    avgCost := ticker16_cost
    qty     := ticker16_qty
    portPct := ticker16_pct

// --- 📈 DRAWING THE GREEN LINE ---
plot(series=avgCost, title="Average Cost Line", color=avgLineColor, linewidth=1, style=plot.style_linebr, trackprice=true)

// --- 🏷️ LABEL LOGIC ---
var label percentLabel = na

if barstate.islast and not na(avgCost)
    float percent_diff = (close - avgCost) / avgCost * 100
    float totalPL      = (close - avgCost) * qty
    string sign        = percent_diff >= 0 ? "+" : ""
    string plSign      = totalPL   >= 0 ? "+" : ""

    string labelText =
         sign   + str.tostring(percent_diff, "#.##") + "%\n" +
         plSign + "$" + str.tostring(totalPL, "#,###.##") + "\n" +
         "Port: " + str.tostring(portPct, "#.##") + "%"

    color bgColor = percent_diff >= 0 ? positiveColor : negativeColor

    if na(percentLabel)
        percentLabel := label.new(
             x        = bar_index,
             y        = avgCost,
             text     = labelText,
             xloc     = xloc.bar_index,
             yloc     = yloc.price,
             style    = label.style_label_left,
             color    = bgColor,
             textcolor = color.white,
             size     = size.normal
             )
    else
        label.set_xy(percentLabel,    bar_index, avgCost)
        label.set_text(percentLabel,  labelText)
        label.set_color(percentLabel, bgColor)
else
    if not na(percentLabel)
        label.delete(percentLabel)
        percentLabel := na
