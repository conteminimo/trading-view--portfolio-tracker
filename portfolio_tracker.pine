float  ticker13_cost = input.float(236.76, title="   Avg. Cost")
float  ticker13_qty  = input.float(24, title="   Quantity")

string ticker14_id = input.string("CSPX", title="14. CSPX (AMS)")
float  ticker14_cost = input.float(569.40, title="   Avg. Cost")
float  ticker14_qty  = input.float(5.281993, title="   Quantity")

string ticker15_id = input.string("CRM", title="15. CRM")
float  ticker15_cost = input.float(245.00, title="   Avg. Cost")
float  ticker15_qty  = input.float(11, title="   Quantity")

string ticker16_id = input.string("IWDA", title="16. IWDA (AMS)")
float  ticker16_cost = input.float(111.34, title="   Avg. Cost")
float  ticker16_qty  = input.float(13.47259, title="   Quantity")

string ticker17_id = input.string("SCHG", title="17. SCHG")
float  ticker17_cost = input.float(25.86, title="   Avg. Cost")
float  ticker17_qty  = input.float(18, title="   Quantity")

// --- 🧠 LOGIC ---
string simpleTicker = syminfo.ticker
float avgCost = na
float qty = na

match(id) => id != "" and (simpleTicker == id or str.contains(syminfo.tickerid, id))

if match(ticker1_id) and syminfo.currency == "CAD"
    avgCost := ticker1_cost
    qty := ticker1_qty
else if match(ticker2_id)
    avgCost := ticker2_cost
    qty := ticker2_qty
else if match(ticker3_id)
    avgCost := ticker3_cost
    qty := ticker3_qty
else if match(ticker4_id)
    avgCost := ticker4_cost
    qty := ticker4_qty
else if match(ticker5_id)
    avgCost := ticker5_cost
    qty := ticker5_qty
else if match(ticker6_id)
    avgCost := ticker6_cost
    qty := ticker6_qty
else if match(ticker7_id)
    avgCost := ticker7_cost
    qty := ticker7_qty
else if match(ticker8_id)
    avgCost := ticker8_cost
    qty := ticker8_qty
else if match(ticker9_id)
    avgCost := ticker9_cost
    qty := ticker9_qty
else if match(ticker10_id)
    avgCost := ticker10_cost
    qty := ticker10_qty
else if match(ticker11_id)
    avgCost := ticker11_cost
    qty := ticker11_qty
else if match(ticker12_id)
    avgCost := ticker12_cost
    qty := ticker12_qty
else if match(ticker13_id)
    avgCost := ticker13_cost
    qty := ticker13_qty
else if match(ticker14_id)
    avgCost := ticker14_cost
    qty := ticker14_qty
else if match(ticker15_id)
    avgCost := ticker15_cost
    qty := ticker15_qty
else if match(ticker16_id)
    avgCost := ticker16_cost
    qty := ticker16_qty
else if match(ticker17_id)
    avgCost := ticker17_cost
    qty := ticker17_qty

// --- 📈 DRAWING THE GREEN LINE ---
// linewidth=1 creates the thin appearance you requested
plot(series=avgCost, title="Average Cost Line", color=avgLineColor, linewidth=1, style=plot.style_linebr, trackprice=true)

// --- 🏷️ LABEL LOGIC ---
var label percentLabel = na

if barstate.islast and not na(avgCost)
    float percent_diff = (close - avgCost) / avgCost * 100
    float totalPL = (close - avgCost) * qty
    string sign = percent_diff >= 0 ? "+" : ""
    string plSign = totalPL >= 0 ? "+" : ""

    string labelText = sign + str.tostring(percent_diff, "#.##") + "%\n" + plSign + "$" + str.tostring(totalPL, "#,###.##")

    color bgColor = percent_diff >= 0 ? positiveColor : negativeColor

    if na(percentLabel)
        percentLabel := label.new(
             x=bar_index,
             y=avgCost,
             text=labelText,
             xloc=xloc.bar_index,
             yloc=yloc.price,
             style=label.style_label_left,
             color=bgColor,
             textcolor=color.white,
             size=size.normal
             )
    else
        label.set_xy(percentLabel, bar_index, avgCost)
        label.set_text(percentLabel, labelText)
        label.set_color(percentLabel, bgColor)
else
    if not na(percentLabel)
        label.delete(percentLabel)
        percentLabel := na